{
  "canon_version": "aegis-jcs-1",
  "description": "Shared canonical-action test vectors for AegisAgent approval-integrity hashing. The SDK (Python/TS/Go) and the Rust gateway MUST all serialize a tool call to the EXACT 'canonical' string below, then SHA-256 it. Byte-equality across languages is the foundation of the fail-closed approval guarantee (approved action_hash == executed action_hash). Scheme aegis-jcs-1: object keys sorted by Unicode code point, compact separators (no spaces), raw UTF-8 (no \\uXXXX escaping of non-ASCII), null for absent resource, JSON numbers as produced by the encoder. The tool_call object always has keys {tool, action, resource, mutates_state, parameters}.",
  "vectors": [
    {
      "name": "ascii_merge",
      "tool_call": {
        "tool": "github",
        "action": "merge_pull_request",
        "resource": "payments-service#482",
        "mutates_state": true,
        "parameters": { "base_branch": "main" }
      },
      "canonical": "{\"action\":\"merge_pull_request\",\"mutates_state\":true,\"parameters\":{\"base_branch\":\"main\"},\"resource\":\"payments-service#482\",\"tool\":\"github\"}"
    },
    {
      "name": "unicode_title_regression",
      "tool_call": {
        "tool": "github",
        "action": "create_pull_request",
        "resource": null,
        "mutates_state": true,
        "parameters": { "title": "Café ☕ déjà vu" }
      },
      "canonical": "{\"action\":\"create_pull_request\",\"mutates_state\":true,\"parameters\":{\"title\":\"Café ☕ déjà vu\"},\"resource\":null,\"tool\":\"github\"}"
    },
    {
      "name": "nested_unicode_keys",
      "tool_call": {
        "tool": "t",
        "action": "x",
        "resource": null,
        "mutates_state": false,
        "parameters": { "z": 1, "a": 2, "é": 3 }
      },
      "canonical": "{\"action\":\"x\",\"mutates_state\":false,\"parameters\":{\"a\":2,\"z\":1,\"é\":3},\"resource\":null,\"tool\":\"t\"}"
    },
    {
      "name": "int_and_bool_params",
      "tool_call": {
        "tool": "github",
        "action": "merge_pull_request",
        "resource": "r",
        "mutates_state": true,
        "parameters": { "pr_number": 482, "draft": false }
      },
      "canonical": "{\"action\":\"merge_pull_request\",\"mutates_state\":true,\"parameters\":{\"draft\":false,\"pr_number\":482},\"resource\":\"r\",\"tool\":\"github\"}"
    }
  ]
}
