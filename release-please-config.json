{
  "packages": {
    ".": {
      "release-type": "simple",
      "target-branch": "release",
      "component": "aegisagent",
      "changelog-path": "CHANGELOG.md",
      "changelog-host": "github",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "prerelease": true,
      "prerelease-type": "beta",
      "versioning": "default",
      "version-file": "version.txt",
      "extra-files": [
        {
          "type": "toml",
          "path": "src/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "toml",
          "path": "src/canon/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "toml",
          "path": "lib/api/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "toml",
          "path": "lib/common/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "toml",
          "path": "lib/policy/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "toml",
          "path": "lib/soc/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "toml",
          "path": "lib/storage/Cargo.toml",
          "jsonpath": "$.package.version"
        }
      ],
      "changelog-sections": [
        { "type": "feat", "section": "Added", "hidden": false },
        { "type": "fix", "section": "Fixed", "hidden": false },
        { "type": "perf", "section": "Performance", "hidden": false },
        { "type": "security", "section": "Security", "hidden": false },
        { "type": "docs", "section": "Documentation", "hidden": false },
        { "type": "refactor", "section": "Changed", "hidden": false },
        { "type": "test", "section": "Tests", "hidden": false },
        { "type": "chore", "section": "Miscellaneous", "hidden": false },
        { "type": "ci", "section": "CI/CD", "hidden": false },
        { "type": "build", "section": "Build", "hidden": false }
      ]
    }
  },
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json"
}
